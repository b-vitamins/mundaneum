# Mundaneum Docker Compose Configuration
# Copy this file to .env and customize as needed

# Ports (change if defaults conflict with local services)
DB_PORT=5432
MEILI_PORT=7700
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
API_PORT=8000
UI_PORT=5173

# Database
POSTGRES_PASSWORD=mundaneum

# Meilisearch (leave empty for no auth in dev)
MEILI_ENV=development
MEILI_MASTER_KEY=

# MinIO
MINIO_USER=mundaneum
MINIO_PASSWORD=mundaneumpass

# Bibliography source
BIBLIOGRAPHY_REPO_URL=https://github.com/b-vitamins/bibliography/
BIBLIOGRAPHY_CHECKOUT_PATH=./.cache/bibliography
BIBLIOGRAPHY_REPO_REF=
BIBLIOGRAPHY_SYNC_TIMEOUT_SECONDS=300
BIBLIOGRAPHY_RUNTIME_SYNC_ENABLED=true
BIBLIOGRAPHY_HOST_CACHE=./.cache/bibliography
