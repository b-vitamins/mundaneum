#!/usr/bin/env bash
#
# s2 — Semantic Scholar dataset management for Mundaneum
#
# Usage:
#   scripts/s2 download [--datasets papers,citations] [--release 2026-02-17]
#   scripts/s2 ingest   [--datasets papers,citations] [--no-index]
#   scripts/s2 sync     — download + ingest in one step
#   scripts/s2 status   — show pipeline status
#   scripts/s2 shell    — open DuckDB interactive shell
#
# All data lives under /data/s2/
# Configuration is read from backend/.env
#

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
BACKEND_DIR="$PROJECT_ROOT/backend"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

log()  { echo -e "${BLUE}[s2]${NC} $*"; }
ok()   { echo -e "${GREEN}[s2]${NC} $*"; }
warn() { echo -e "${YELLOW}[s2]${NC} $*"; }
err()  { echo -e "${RED}[s2]${NC} $*" >&2; }

# All Python runs through Poetry venv
py() { cd "$BACKEND_DIR" && poetry run python "$@"; }

# ── Load settings ────────────────────────────────────────

load_env() {
    if [[ -f "$BACKEND_DIR/.env" ]]; then
        set -a
        # shellcheck disable=SC1091
        source "$BACKEND_DIR/.env"
        set +a
    fi

    S2_CORPUS_PATH="${S2_CORPUS_PATH:-/data/s2/corpus.duckdb}"
    S2_SHARDS_PATH="${S2_SHARDS_PATH:-/data/s2/shards}"
    S2_API_KEY="${S2_API_KEY:-}"
}

# ── Ensure dependencies ─────────────────────────────────

check_deps() {
    if ! py -c "import duckdb" 2>/dev/null; then
        warn "duckdb not installed in Poetry venv. Installing..."
        cd "$BACKEND_DIR" && poetry run pip install duckdb 2>/dev/null || {
            err "Failed to install duckdb. Run: cd backend && poetry run pip install duckdb"
            exit 1
        }
        ok "duckdb installed."
    fi
}

# ── Ensure /data/s2 exists ───────────────────────────────

ensure_dirs() {
    if [[ ! -d "/data/s2" ]]; then
        log "Creating /data/s2..."
        mkdir -p /data/s2 2>/dev/null || {
            err "Cannot create /data/s2. Create it manually: sudo mkdir -p /data/s2 && sudo chown \$(whoami) /data/s2"
            exit 1
        }
    fi
    mkdir -p "$S2_SHARDS_PATH"
}

# ── Commands ─────────────────────────────────────────────

cmd_download() {
    if [[ -z "$S2_API_KEY" ]]; then
        err "S2_API_KEY not set. Add it to $BACKEND_DIR/.env"
        exit 1
    fi
    log "Starting download..."
    py -m app.services.s2_ingest download "$@"
    ok "Download complete."
}

cmd_ingest() {
    log "Starting ingestion..."
    py -m app.services.s2_ingest ingest "$@"
    ok "Ingestion complete."
}

cmd_sync() {
    log "Full sync: download + ingest"
    cmd_download "$@"
    cmd_ingest "$@"
    ok "Full sync complete."
}

cmd_status() {
    py -m app.services.s2_ingest status

    echo ""
    log "Disk usage:"
    if [[ -d "/data/s2" ]]; then
        du -sh /data/s2/* 2>/dev/null || echo "  (empty)"
    else
        echo "  /data/s2 does not exist"
    fi
}

cmd_shell() {
    if [[ ! -f "$S2_CORPUS_PATH" ]]; then
        err "DuckDB file not found at $S2_CORPUS_PATH"
        err "Run 'scripts/s2 sync' first."
        exit 1
    fi
    log "Opening DuckDB shell (read-only)..."
    log "Database: $S2_CORPUS_PATH"
    py -m app.services.s2_shell "$S2_CORPUS_PATH"
}

# ── Main ─────────────────────────────────────────────────

load_env

case "${1:-help}" in
    download)
        shift
        check_deps
        ensure_dirs
        cmd_download "$@"
        ;;
    ingest)
        shift
        check_deps
        ensure_dirs
        cmd_ingest "$@"
        ;;
    sync)
        shift
        check_deps
        ensure_dirs
        cmd_sync "$@"
        ;;
    status)
        shift || true
        check_deps
        cmd_status
        ;;
    shell)
        shift || true
        check_deps
        cmd_shell
        ;;
    help|--help|-h)
        echo "Usage: scripts/s2 <command> [options]"
        echo ""
        echo "Commands:"
        echo "  download  Download S2 dataset shards"
        echo "  ingest    Ingest downloaded shards into DuckDB"
        echo "  sync      Download + ingest (full pipeline)"
        echo "  status    Show pipeline status"
        echo "  shell     Interactive DuckDB SQL shell"
        echo ""
        echo "Options (download/ingest/sync):"
        echo "  --datasets papers,citations  Comma-separated dataset names"
        echo "  --all                        ALL datasets (core + embeddings + full-text)"
        echo "  --release 2026-02-17         Specific release date"
        echo "  --no-index                   Skip index building (ingest only)"
        echo ""
        echo "Core datasets: papers, citations, authors, abstracts, tldrs, paper-ids, publication-venues"
        echo "All datasets:  core + embeddings-specter_v2, s2orc_v2"
        echo ""
        echo "Data directory: /data/s2/"
        echo "Configuration: $BACKEND_DIR/.env"
        ;;
    *)
        err "Unknown command: $1"
        err "Run 'scripts/s2 help' for usage."
        exit 1
        ;;
esac
